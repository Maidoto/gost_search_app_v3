# Telegram API credentials for a personal account.
# Get them at https://my.telegram.org -> API development tools.
API_ID=123456
API_HASH=put_your_api_hash_here

# Your phone number in international format. Example: +998901234567
# You can leave it empty; Telethon will ask in the console.
PHONE=

# Optional for cloud hosts like Render.
# Generate it locally with: python clock_avatar.py --session-string
TELETHON_SESSION_STRING=

# Time zone used on the avatar.
TIMEZONE=Asia/Tashkent
# Used only if Windows/Python cannot find TIMEZONE data.
UTC_OFFSET=+05:00

# Telegram caches profile photos and has flood limits.
# Keep this at 60 or higher.
UPDATE_SECONDS=60

# true = delete only the previous photo uploaded by this script.
# It does not delete photos that existed before the script.
DELETE_PREVIOUS_SCRIPT_PHOTOS=true

# Date under the clock. Set SHOW_DATE=false to hide it.
SHOW_DATE=true
DATE_FORMAT=%d.%m.%Y
